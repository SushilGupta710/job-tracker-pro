{
  "manifest_version": 3,
  "name": "Job Tracker Pro",
  "version": "1.0",
  "description": "Save and track job opportunities across the web",
  "icons": {
    "16": "icons/main-logo.png",
    "32": "icons/main-logo.png",
    "48": "icons/main-logo.png",
    "128": "icons/main-logo.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:4200/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.lever.co/*",
    "https://*.greenhouse.com/*",
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline';"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Tracker Pro"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/main-logo.png"],
      "matches": ["<all_urls>"]
    }
  ]
}